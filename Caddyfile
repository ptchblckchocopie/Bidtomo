# Shared security headers snippet
(security_headers) {
    header {
        Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
        Permissions-Policy "camera=(), microphone=(), geolocation=()"
        -Server
    }
}

# Production HTTPS (browser access, auto Let's Encrypt)
{$DOMAIN:localhost} {
    import security_headers

    # SSE routes — log with query strings replaced to avoid leaking JWT tokens
    handle /sse/* {
        log {
            output stderr
            format filter {
                wrap console
                fields {
                    request>uri replace "token=[^&]*" "token=REDACTED"
                }
            }
        }
        uri strip_prefix /sse
        reverse_proxy prod-sse:3002
    }

    handle /api/* {
        reverse_proxy prod-cms:3001
    }

    handle /admin/* {
        reverse_proxy prod-cms:3001
    }

    handle /media/* {
        reverse_proxy prod-cms:3001
    }

    handle {
        reverse_proxy prod-cms:3001
    }
}

# Staging HTTPS (auto Let's Encrypt — sslip.io subdomains resolve correctly)
{$STAGING_DOMAIN:staging.localhost} {
    import security_headers

    handle /sse/* {
        log {
            output stderr
            format filter {
                wrap console
                fields {
                    request>uri replace "token=[^&]*" "token=REDACTED"
                }
            }
        }
        uri strip_prefix /sse
        reverse_proxy staging-sse:3002
    }

    handle /api/* {
        reverse_proxy staging-cms:3001
    }

    handle /admin/* {
        reverse_proxy staging-cms:3001
    }

    handle /media/* {
        reverse_proxy staging-cms:3001
    }

    handle {
        reverse_proxy staging-cms:3001
    }
}

# HTTP :80 — server-to-server bridge calls from Vercel
:80 {
    @staging_host host {$STAGING_DOMAIN:staging.localhost}

    # Staging requests (Vercel Preview sends Host: staging.188-166-216-176.sslip.io)
    handle @staging_host {
        handle /sse/* {
            log {
                output stderr
                format filter {
                    wrap console
                    fields {
                        request>uri replace "token=[^&]*" "token=REDACTED"
                    }
                }
            }
            uri strip_prefix /sse
            reverse_proxy staging-sse:3002
        }

        handle /api/* {
            reverse_proxy staging-cms:3001
        }

        handle /admin/* {
            reverse_proxy staging-cms:3001
        }

        handle /media/* {
            reverse_proxy staging-cms:3001
        }

        handle {
            reverse_proxy staging-cms:3001
        }
    }

    # Default (bare IP from Vercel Production) → production
    handle /sse/* {
        log {
            output stderr
            format filter {
                wrap console
                fields {
                    request>uri replace "token=[^&]*" "token=REDACTED"
                }
            }
        }
        uri strip_prefix /sse
        reverse_proxy prod-sse:3002
    }

    handle /api/* {
        reverse_proxy prod-cms:3001
    }

    handle /admin/* {
        reverse_proxy prod-cms:3001
    }

    handle /media/* {
        reverse_proxy prod-cms:3001
    }

    handle {
        reverse_proxy prod-cms:3001
    }
}
