# SvelteKit Frontend Configuration

# Server-side only — CMS backend URL (used by bridge routes)
# Production: http://188.166.216.176 (bare IP, Caddy :80 default → prod)
# Staging:    https://staging.188-166-216-176.sslip.io (HTTPS required — HTTP redirects strip auth headers)
# Local dev:  http://localhost:3001
CMS_URL=http://localhost:3001

# Public — SSE service URL (used by browser for real-time updates)
# Production: https://188-166-216-176.sslip.io/sse
# Staging:    https://staging.188-166-216-176.sslip.io/sse
# Local dev:  http://localhost:3002
PUBLIC_SSE_URL=http://localhost:3002

# Sentry environment tag (development | staging | production)
PUBLIC_SENTRY_ENVIRONMENT=development
