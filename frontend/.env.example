# SvelteKit Frontend Configuration

# Server-side only — CMS backend URL (used by bridge routes)
CMS_URL=http://localhost:3001

# Public — SSE service URL (used by browser for real-time updates)
# In production with Caddy: https://api.bidmo.to/sse
# In local dev: http://localhost:3002
PUBLIC_SSE_URL=http://localhost:3002
