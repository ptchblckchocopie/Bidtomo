# Staging Environment
# Copy to .env in /opt/bidtomo-staging/ and fill in values

# Backend URL (staging subdomain)
SERVER_URL=https://staging.188-166-216-176.sslip.io

# Frontend URL on Vercel (for CORS — Vercel preview deployments)
FRONTEND_URL=https://bidtomo-*.vercel.app

# PostgreSQL — MUST differ from production
POSTGRES_DB=marketplace
POSTGRES_USER=postgres
POSTGRES_PASSWORD=staging-change-this-password

# Payload CMS Secret — MUST differ from production (different JWTs)
PAYLOAD_SECRET=staging-change-this-to-a-different-secret

# S3 Storage (shared bucket — filenames are unique hashes)
AWS_ACCESS_KEY_ID=your-spaces-access-key
AWS_SECRET_ACCESS_KEY=your-spaces-secret-key
S3_REGION=sgp1
S3_ENDPOINT=https://sgp1.digitaloceanspaces.com
S3_BUCKET=veent

# Sentry Error Tracking (optional)
SENTRY_DSN=

# Database Push — true for staging (auto-sync schema, no formal migrations)
DB_PUSH=true

# Emails disabled — empty key makes Resend API calls fail silently
RESEND_API_KEY=

# Backups disabled for staging
BACKUP_ENABLED=false
