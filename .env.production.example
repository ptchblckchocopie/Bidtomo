# DigitalOcean Production Environment
# Copy to .env and fill in values before deploying

# Domain — your domain or droplet IP (Caddy uses this for HTTPS)
# Use a domain for automatic Let's Encrypt SSL, or IP for HTTP-only
DOMAIN=your-domain.com

# Backend URL (must match DOMAIN with https://)
SERVER_URL=https://your-domain.com

# Frontend URL on Vercel (for CORS)
FRONTEND_URL=https://your-frontend.vercel.app

# PostgreSQL
POSTGRES_DB=marketplace
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-to-a-strong-password

# Payload CMS Secret — shared across CMS, SSE, and bid-worker for JWT
PAYLOAD_SECRET=change-this-to-a-long-random-string

# S3 Storage (DigitalOcean Spaces)
AWS_ACCESS_KEY_ID=your-spaces-access-key
AWS_SECRET_ACCESS_KEY=your-spaces-secret-key
S3_REGION=sgp1
S3_ENDPOINT=https://sgp1.digitaloceanspaces.com
S3_BUCKET=veent

# Sentry Error Tracking (optional)
SENTRY_DSN=

# Database Push (set to true for staging, false for production)
DB_PUSH=false

# Automated Backup
BACKUP_ENABLED=false
BACKUP_CRON_SCHEDULE=0 3 * * *
BACKUP_RETENTION_DAYS=7
